# Caddy — proxy reverso do dev local multi-perfil (fase 0.5). Escuta a porta 80 do host.
# Cada subdomínio de produto cai no MESMO container frontend (Next decide o perfil pelo host,
# via middleware x-meada-subdomain); api.meadadigital.local cai no backend.
#
# Nomes de serviço (frontend/backend) resolvem pela rede interna do docker-compose.

{
	# dev local: sem HTTPS automático (não há certificado pra *.meadadigital.local).
	auto_https off
	# sem o endpoint de admin do Caddy (não precisamos; reduz superfície).
	admin off
}

# Frontend — domínio base + os 8 subdomínios de perfil.
# Prefixo http:// EXPLÍCITO: força o Caddy a escutar a porta 80 (sem ele + auto_https off,
# o Caddy bind só :443 e a 80 fica morta — connection reset).
http://meadadigital.local,
http://meada.meadadigital.local,
http://processo.meadadigital.local,
http://dental.meadadigital.local,
http://sushi.meadadigital.local,
http://mesa.meadadigital.local,
http://salao.meadadigital.local,
http://pousada.meadadigital.local,
http://academia.meadadigital.local,
http://pet.meadadigital.local,
http://oficina.meadadigital.local,
http://nutri.meadadigital.local {
	reverse_proxy frontend:3000
}

# Backend — API.
http://api.meadadigital.local {
	reverse_proxy backend:8095
}

# Projeto externo muda (Laravel) — subdomínio próprio, aponta pro nginx do muda.
# Host explícito casa antes do wildcard *.meadadigital.local abaixo (que vai pro frontend).
# Prod: muda.meadadigital.com (mesmo reverse_proxy, com TLS).
http://muda.meadadigital.local {
	reverse_proxy muda-nginx:80
}

# HOMOLOG do muda (branch `homolog` do repo github.com/igorhaf/muda).
# Ambiente espelho, banco e credenciais próprios. Prod: mudahomolog.meadadigital.com.
http://mudahomolog.meadadigital.local {
	reverse_proxy mudahomolog-nginx:80
}

# Túnel ngrok da muda (DEV) — domínio fixo reservado na conta, usado para callbacks
# externos (Mercado Pago, Google OAuth, MelhorEnvio) e para o webhook do WhatsApp.
# Cadeia: ngrok (TLS) -> Caddy :80 -> muda-nginx:80.
#
# http:// explícito: o ngrok TERMINA o TLS e entrega em HTTP na 80; sem o prefixo o
# Caddy tentaria emitir cert ACME para um domínio que não é dele.
#
# header_up X-Forwarded-Proto https: o Caddy recebe a request em HTTP e, por padrão,
# repassaria X-Forwarded-Proto=http — o Laravel geraria os assets como http:// e o
# navegador bloquearia tudo por mixed content na página https do ngrok. Como sabemos
# que o ngrok termina TLS, cravamos https aqui.
http://slum-feminist-speculate.ngrok-free.dev {
	reverse_proxy muda-nginx:80 {
		header_up X-Forwarded-Proto https
	}
}

# Projeto externo semente-doce (Laravel — doceria) — subdomínio próprio.
# Prod: semente-doce.meadadigital.com (mesmo reverse_proxy, com TLS).
http://semente-doce.meadadigital.local {
	reverse_proxy semente-nginx:80
}

# Projeto externo germinar (Laravel — site institucional de doulas) — subdomínio próprio.
# Prod: germinar.meadadigital.com (mesmo reverse_proxy, com TLS).
http://germinar.meadadigital.local {
	reverse_proxy germinar-nginx:80
}

# Projeto externo pindorama (Laravel — marketplace de saúde integrativa) — subdomínio próprio.
# Casa antes do wildcard *.meadadigital.local, senão o middleware do meada engoliria o host
# (resolveCompany('pindorama') → inexistente → redirect pra base). Prod: pindorama.meadadigital.com.
http://pindorama.meadadigital.local {
	reverse_proxy pindorama-nginx:80
}

# Projeto externo conexao-municipio (Laravel API + Next) — subdomínio próprio.
# Path-based mesma-origem: /api/* vai pro backend Laravel; o resto pro frontend Next.
# Prod: conexao-municipio.meadadigital.com.
http://conexao-municipio.meadadigital.local {
	handle /api/* {
		reverse_proxy conexao-municipio-backend:8000
	}
	handle {
		reverse_proxy conexao-municipio-frontend:3000
	}
}

# Projeto externo soar (Laravel API + React/Vite) — subdomínio próprio.
# Path-based mesma-origem: /api/* vai pro backend Laravel; o resto pro frontend Vite.
# Prod: soar.meadadigital.com.
http://soar.meadadigital.local {
	handle /api/* {
		reverse_proxy soar-backend:8000
	}
	handle {
		reverse_proxy soar-frontend:3130
	}
}

# Catch-all dos SUBDOMÍNIOS DE EMPRESA (slug.meadadigital.local) — qualquer host *.meadadigital.local
# que NÃO casou os blocos acima (nichos fixos + api) cai aqui e vai pro frontend. Necessário porque
# o "Acessar admin" do root abre {slug}.meadadigital.local/auth/confirm, e os slugs de empresa
# (suplementos-modelo, belezapura, ...) não estão na lista fixa. O Next resolve o perfil/empresa
# pelo host (middleware → resolveCompany). Caddy casa o host mais específico primeiro, então
# api./meada./sushi./... continuam roteando certo; só o resto (slugs) cai neste wildcard.
http://*.meadadigital.local {
	reverse_proxy frontend:3000
}

# =============================================================================
# CMS — domínios PRÓPRIOS de tenant (SM-N). Template de PRODUÇÃO — NÃO ativar em dev
# (o dev roda auto_https off; isto exige :443 + emissão de cert real). Em prod, mover o
# bloco `on_demand_tls`/`tls` pro escopo global e adicionar o site catch-all abaixo.
#
# On-demand TLS: o Caddy emite cert sob demanda pra QUALQUER host que chegar, MAS só depois
# de perguntar ao backend se o domínio é permitido (verificado + publicado). Sem o "ask", um
# terceiro apontaria um domínio pro nosso IP e forçaria emissão de cert.
#
#   {
#       on_demand_tls {
#           ask http://backend:8095/public/cms/tls-allowed
#       }
#   }
#
#   # Catch-all: qualquer host que NÃO seja meadadigital.* cai aqui (domínio custom de tenant).
#   # O Next resolve o tenant pelo host (middleware → /p/by-domain/{host}); o backend serve o
#   # /public/cms/by-domain. O ask acima trava a emissão de cert aos domínios verificados.
#   https:// {
#       tls {
#           on_demand
#       }
#       reverse_proxy frontend:3000
#   }
# =============================================================================
