# .env.example — copie para .env.local (gitignored) e preencha com valores reais.
#   cp .env.example .env.local
#
# Estas duas vars são NEXT_PUBLIC_* → embarcadas no bundle do browser. Isso é
# SEGURO: a anon key do Supabase é pública por design; o que protege os dados é o
# RLS (Row Level Security) no banco, não o segredo da key. Nunca coloque aqui uma
# service_role key (essa sim é secreta e só vive no backend Spring).

NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=cole-aqui-a-anon-key
