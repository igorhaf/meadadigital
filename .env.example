# ==========================================================================
# .env.example — referência das variáveis de ambiente do backend whatsapp.
# Copie para .env (que é gitignored) e preencha com valores reais.
#   cp .env.example .env  &&  $EDITOR .env
#
# Regra do application.yml: as variáveis SEM default são fail-fast — se faltarem,
# o Spring não sobe. As COM default podem ficar de fora (mostradas comentadas).
# ==========================================================================

# ---- Banco (Supabase dev) — OBRIGATÓRIAS, sem default --------------------
# URL JDBC do Postgres do Supabase. Use a porta 5432 (sessão) para o pool.
# Formato típico Supabase:
#   jdbc:postgresql://<host>:5432/postgres?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://db.xxxxxxxxxxxx.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=troque-pela-senha-do-supabase-dev

# ---- Webhook (Evolution → backend) — OBRIGATÓRIA, sem default -----------
# Segredo compartilhado: o mesmo valor configurado no webhook da instância
# Evolution. Filtra requisições não autenticadas (WebhookSecretFilter).
WEBHOOK_SECRET=troque-por-um-segredo-forte

# ---- IA (Gemini) — api-key e model OBRIGATÓRIAS, sem default ------------
GEMINI_API_KEY=troque-pela-sua-chave-gemini
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL tem default (não precisa setar):
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ---- Servidor — opcional (default 8080 no application.yml) --------------
# Descomente se a 8080 estiver ocupada localmente (ex. outro serviço). Spring
# faz relaxed binding SERVER_PORT → server.port, sem mexer no yaml.
# SERVER_PORT=8095

# ---- Admin / Auth (painel — camada 4.1+) -------------------------------
# SUPABASE_JWT_SECRET: secret HS256 que valida tokens Supabase no filtro JWT do
#   admin. Pegue em Settings → API → JWT Settings → "Reveal". OBRIGATÓRIA, sem
#   default (fail-fast: Spring não sobe sem isso).
SUPABASE_JWT_SECRET=cole-o-jwt-secret-do-supabase
# CSV de emails tratados como super-admin (sem linha em public.users):
ADMIN_SUPER_ADMIN_EMAILS=voce@exemplo.com
# Origens do frontend aceitas no CORS de /admin/** (default http://localhost:3000):
ADMIN_CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Evolution API — base-url OBRIGATÓRIA, sem default ------------------
# Ainda não há Evolution provisionada: um placeholder válido permite o app
# SUBIR (o EvolutionClient só falha ao TENTAR enviar, não no boot). Troque
# pela URL real quando provisionar a Evolution.
EVOLUTION_BASE_URL=http://localhost:8080
# Timeouts têm default (não precisa setar):
# EVOLUTION_CONNECT_TIMEOUT_MS=5000
# EVOLUTION_READ_TIMEOUT_MS=30000
